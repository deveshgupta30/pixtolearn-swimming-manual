{
  "name": "pixtolearn-manual",
  "version": "1.0.1",
  "description": "Multi-language instruction manual website for PixToLearn Swimming",
  "main": "server/server.js",
  "scripts": {
    "server": "cd server && node server.js",
    "server:dev": "cd server && npx nodemon server.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install",
    "build": "cd client && npm run build",
    "build:prod": "cd client && npm run build && cd ../server && npm ci --only=production",
    "seed": "cd server && node seedDatabase.js",
    "start": "cd server && npm start",
    "heroku-postbuild": "npm run build",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "test:api": "cd server && npm test",
    "test:client": "cd client && npm test"
  },
  "keywords": ["mern", "instruction-manual", "i18n", "education"],
  "author": "PixToLearn",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
